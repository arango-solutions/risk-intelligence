{
    "graphId": "KnowledgeGraph",
    "name": "sentries_risk_heatmap",
    "description": "Risk heatmap theme: colors nodes by pre-computed riskLevel (high/medium/low) for broad Visualizer compatibility",
    "nodeConfigMap": {
        "Person": {
            "background": {
                "color": "#e2e8f0",
                "iconName": "fa6-solid:user"
            },
            "labelAttribute": "label",
            "hoverInfoAttributes": ["label", "party_id", "riskScore", "inferredRisk", "riskLevel", "dataSource"],
            "rules": [
                {
                    "name": "High Risk",
                    "condition": "riskLevel == 'high'",
                    "background": { "color": "#e53e3e" }
                },
                {
                    "name": "Medium Risk",
                    "condition": "riskLevel == 'medium'",
                    "background": { "color": "#ecc94b" }
                },
                {
                    "name": "Low Risk",
                    "condition": "riskLevel == 'low'",
                    "background": { "color": "#38a169" }
                },
                {
                    "name": "Synthetic Entity",
                    "condition": "dataSource == 'Synthetic'",
                    "background": { "iconName": "fa6-solid:vial" }
                }
            ]
        },
